# ── Secrets — NEVER commit ───────────────────────────────────────────────────
.env
*.env
# (.env.example is kept: it does not match the patterns above)
# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
# ── Skill runtime artifacts (generated, not source) ──────────────────────────
data/
out/
output/
narration/
edit/
*.tmp
*.webm
*.mp4
*.aiff
# ── OS / editor ──────────────────────────────────────────────────────────────
.DS_Store
*.swp
.idea/
.vscode/
node_modules/
.pikiloom/*
!.pikiloom/skills/
!.pikiloom/skills/**
# ── Local agent scaffolding (Claude Code / Codex symlink bridges) ────────────
.claude/
.agents/
# ── Personal, un-shared project skill (real path under .pikiloom/skills) ──────
# .pikiloom/skills/** is tracked above; re-ignore this dev-only deploy tool so a
# `git add -A` (incl. the push skill itself) never commits or publishes it.
.pikiloom/skills/push/
